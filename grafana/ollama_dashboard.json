        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "nvidia_smi_utilization_gpu_ratio{job=\"$job\", instance=\"$instance\"}",
          "legendFormat": "GPU {{gpu_index}} {{gpu_name}}",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
